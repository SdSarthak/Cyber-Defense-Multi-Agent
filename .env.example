# ─── Google AI Studio ─────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_google_ai_studio_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cyberdefense
POSTGRES_USER=cyberdefense
POSTGRES_PASSWORD=strongpassword123

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── Elasticsearch ────────────────────────────────────────────────────────────
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_USER=elastic
ELASTICSEARCH_PASSWORD=elastic123

# ─── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_THREATS=threat_intel
CHROMA_COLLECTION_VULNS=vulnerability_kb
CHROMA_COLLECTION_COMPLIANCE=compliance_policies

# ─── API ──────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=supersecretkey_change_in_production
API_ALGORITHM=HS256
API_ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=http://localhost:3000

# ─── Agent Config ─────────────────────────────────────────────────────────────
AGENT_MAX_ITERATIONS=10
AGENT_TIMEOUT_SECONDS=120
THREAT_DETECTION_INTERVAL=30
LOG_ANALYSIS_BATCH_SIZE=100
VULN_SCAN_INTERVAL=3600

# ─── Simulation ────────────────────────────────────────────────────────────────
SIMULATION_MODE=true
SIMULATION_LOG_RATE=10
SIMULATION_ATTACK_PROBABILITY=0.05
